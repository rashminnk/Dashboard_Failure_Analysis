# Copy this file to .streamlit/secrets.toml and fill in the real values.
# Never commit secrets.toml to git.
#
# SharePoint auth uses your normal M365 email + password.
# No Azure App Registration required.
#
# How to find SHAREPOINT_FILE_URL (server-relative path):
#   1. Open the Excel file in SharePoint/Teams in your browser.
#   2. Click the "..." menu → Details → path shown is the server-relative path.
#   Example: /teams/MyTeam/Shared Documents/General/Report.xlsx
#
# How to find SHAREPOINT_SITE_URL:
#   Take just the site root from the SharePoint URL, e.g.:
#   https://yourcompany.sharepoint.com/teams/MyTeam

M365_USERNAME         = "your.email@yourcompany.com"
M365_PASSWORD         = "your-m365-password"
SHAREPOINT_SITE_URL   = "https://yourcompany.sharepoint.com/teams/YourTeam"
SHAREPOINT_FILE_URL   = "/teams/YourTeam/Shared Documents/General/Jobs_Status_Report_2026.xlsx"
